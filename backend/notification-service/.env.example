# ─────────────────────────────────────────────────────────────
# Notification Service — Environment Variables
# cp .env.example .env   rồi điền giá trị thực
# ─────────────────────────────────────────────────────────────

PORT=8005
NODE_ENV=development

DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASS=root
DB_NAME=mg_notification

# Email
EMAIL_PROVIDER=smtp

# SMTP (Email) — dùng Gmail App Password hoặc nhà cung cấp SMTP khác khi EMAIL_PROVIDER=smtp
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_gmail@gmail.com
SMTP_PASS=your_gmail_app_password
EMAIL_FROM=Nhà Thuốc Minh Giang <noreply@minhgiangpharma.vn>

# SMS
SMS_PROVIDER=generic_http
SMS_BRAND_NAME=MinhGiang

# Cách 1: SMS generic HTTP provider
SMS_API_URL=https://sms-provider.example.com/send
SMS_API_KEY=your_real_sms_api_key
SMS_API_KEY_HEADER=Authorization
SMS_API_KEY_PREFIX=Bearer
SMS_TO_FIELD=to
SMS_MESSAGE_FIELD=message
SMS_BRAND_FIELD=brand_name

# Cách 2: Twilio provider (đặt SMS_PROVIDER=twilio nếu dùng)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=

GATEWAY_URL=http://localhost:8000

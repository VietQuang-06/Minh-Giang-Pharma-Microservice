# ─────────────────────────────────────────────────────────────
# Identity Service — Environment Variables
# cp .env.example .env   rồi điền giá trị thực
# ─────────────────────────────────────────────────────────────

PORT=8001
NODE_ENV=development

# Database (MySQL)
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASS=root
DB_NAME=mg_identity

# JWT — dùng cùng giá trị với api-gateway
JWT_SECRET=change_me_to_a_random_32_char_string
JWT_EXPIRES_IN=2h
CUSTOMER_ACCESS_TOKEN_TTL=2h
CUSTOMER_REFRESH_TOKEN_TTL=14d
ADMIN_ACCESS_TOKEN_TTL=2h
ADMIN_REFRESH_TOKEN_TTL=1d
POS_ACCESS_TOKEN_TTL=8h
POS_REFRESH_TOKEN_TTL=12h

# URL của API Gateway (để CORS nội bộ nếu cần)
GATEWAY_URL=http://localhost:8000
FRONTEND_ORIGIN=http://localhost:3000

# Notification/OTP
NOTIFICATION_SERVICE_URL=http://localhost:8005
NOTIFICATION_TIMEOUT_MS=3000
NOTIFICATION_REQUIRED=true
OTP_TTL_SECONDS=300
OTP_COOLDOWN_SECONDS=60
OTP_DAILY_LIMIT=5
OTP_MAX_ATTEMPTS=5
OTP_DEBUG_RESPONSE=false

# Token nội bộ nếu service khác gọi thẳng Identity để cộng điểm loyalty
GATEWAY_INTERNAL_TOKEN=change_me_gateway_internal_token
INTERNAL_SERVICE_TOKEN=change_me_internal_service_token
SOCIAL_AUTH_MOCK=false

# ─── Zalo OAuth (đăng nhập Zalo) ─────────────────────────────────────────────
# Đăng ký app tại: https://developers.zalo.me → Lấy App ID + Secret
ZALO_APP_ID=your_zalo_app_id
ZALO_APP_SECRET=your_zalo_app_secret
ZALO_REDIRECT_URI=http://localhost:8000/api/identity/auth/zalo/callback

# ─── Google OAuth (đăng nhập Google) ─────────────────────────────────────────
# Đăng ký app tại: https://console.cloud.google.com → Credentials → OAuth 2.0 Client
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=http://localhost:8000/api/identity/auth/google/callback
